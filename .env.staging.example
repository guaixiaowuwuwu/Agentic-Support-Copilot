APP_ENV=staging
SUPPORT_COPILOT_STORE=postgres
SUPPORT_COPILOT_AUTH_MODE=trusted_headers
SUPPORT_COPILOT_SEED_DEMO_DATA=false
SUPPORT_COPILOT_LLM_ENABLED=false
# OpenAI-compatible LLM and embedding providers are opt-in. Keep API keys in
# mounted secrets or a secret manager, not in this file.
# SUPPORT_COPILOT_LLM_BASE_URL=https://api.openai.com/v1
# SUPPORT_COPILOT_LLM_MODEL=gpt-4.1-mini
# SUPPORT_COPILOT_LLM_API_KEY_FILE=/run/secrets/llm_api_key
# SUPPORT_COPILOT_EMBEDDING_PROVIDER=openai_compatible
# SUPPORT_COPILOT_EMBEDDING_BASE_URL=https://api.openai.com/v1
# SUPPORT_COPILOT_EMBEDDING_MODEL=text-embedding-3-small
# SUPPORT_COPILOT_EMBEDDING_API_KEY_FILE=/run/secrets/embedding_api_key
SUPPORT_COPILOT_ALLOWED_TOOLS=log_search,db_read,jira_search,github_search
SUPPORT_COPILOT_LOG_LEVEL=INFO

# API/Web ports exposed by infra/docker-compose.staging.yml.
API_PORT=8000
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Browser-facing API base. Keep /support-api when Web proxies browser calls
# through the Next.js server and injects trusted identity server-side.
NEXT_PUBLIC_API_BASE=/support-api
NEXT_PUBLIC_SUPPORT_COPILOT_ENV=staging
NEXT_PUBLIC_SUPPORT_COPILOT_DEMO_MODE=false
NEXT_PUBLIC_SUPPORT_COPILOT_LOCAL_IDENTITY_HEADERS=false

# Runtime service locations inside the staging Docker network.
REDIS_URL=redis://redis:6379/0
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_BUCKET=support-copilot

# PostgreSQL sizing and retention knobs for the operational runbook.
SUPPORT_COPILOT_BACKUP_RETENTION_DAYS=30
SUPPORT_COPILOT_AUDIT_RETENTION_DAYS=365
SUPPORT_COPILOT_RUN_TRACE_RETENTION_DAYS=180

# Secrets are mounted from infra/secrets/staging/*.txt by the staging compose
# file. Do not put real secret values in this file.
