# Backend
API_HOST=0.0.0.0
API_PORT=8000
APP_ENV=development
SUPPORT_COPILOT_AUTH_MODE=local_headers
# Staging/production should use SUPPORT_COPILOT_AUTH_MODE=trusted_headers and
# provide this value from a secret manager. A trusted ingress, API gateway, SSO
# proxy, or the Next.js server forwards it to the API; browsers must not know it.
# SUPPORT_COPILOT_TRUSTED_IDENTITY_SECRET=replace-me
# SUPPORT_COPILOT_API_TRUSTED_IDENTITY_SECRET=replace-me

# Storage profile.
# Local development and E2E may use SUPPORT_COPILOT_STORE=memory for speed.
# Staging and production should use SUPPORT_COPILOT_STORE=postgres.
SUPPORT_COPILOT_STORE=postgres
SUPPORT_COPILOT_DATABASE_URL=postgresql://support:support@127.0.0.1:5432/support_copilot
# Set false when a deployment runs scripts/db_migrate.py or the api-migrate
# container before starting API replicas.
SUPPORT_COPILOT_AUTO_MIGRATE=true
# Local demos seed sample data by default. Staging/production should normally
# set this false and import tenant-scoped knowledge explicitly.
SUPPORT_COPILOT_SEED_DEMO_DATA=true
# Any secret can be supplied through *_FILE, for example:
# SUPPORT_COPILOT_DATABASE_URL_FILE=/run/secrets/support_copilot_database_url

# Destructive PostgreSQL integration tests are opt-in. Keep this unset unless
# you are pointing at a disposable local database.
# SUPPORT_COPILOT_TEST_DATABASE_URL=postgresql://support:support@127.0.0.1:5432/support_copilot

# OpenAI-compatible LLM API for reply draft generation.
# Keep disabled for deterministic local demos; set to true after filling model/API key.
SUPPORT_COPILOT_LLM_ENABLED=false
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=support-copilot-local
LLM_API_KEY=replace-me
LLM_TIMEOUT_SECONDS=20
LLM_RETRY_COUNT=1
LLM_RETRY_BACKOFF_SECONDS=0.2
LLM_RATE_LIMIT_PER_MINUTE=60

# Prompt and verifier policy configuration. Use *_FILE to load longer managed prompts.
# SUPPORT_COPILOT_LLM_SYSTEM_PROMPT_FILE=/etc/support-copilot/prompts/system.txt
# SUPPORT_COPILOT_REPLY_POLICY_FILE=/etc/support-copilot/prompts/reply-policy.txt
# SUPPORT_COPILOT_CITATION_POLICY_FILE=/etc/support-copilot/prompts/citation-policy.txt
SUPPORT_COPILOT_PROMPT_VERSION=support-copilot-v1
SUPPORT_COPILOT_CITATION_HEADING=引用来源：

# OpenAI-compatible embedding API for vector ingestion and retrieval queries.
# Keep hashing for deterministic local tests; switch provider when a real embedding backend is available.
SUPPORT_COPILOT_EMBEDDING_PROVIDER=hashing
SUPPORT_COPILOT_EMBEDDING_BASE_URL=https://api.openai.com/v1
SUPPORT_COPILOT_EMBEDDING_MODEL=text-embedding-3-small
SUPPORT_COPILOT_EMBEDDING_API_KEY=replace-me
SUPPORT_COPILOT_EMBEDDING_TIMEOUT_SECONDS=20
SUPPORT_COPILOT_EMBEDDING_DIMENSIONS=1536

# Read-only tool whitelist and optional real backends.
# When a backend is not configured, the MVP keeps deterministic demo summaries.
SUPPORT_COPILOT_ALLOWED_TOOLS=log_search,db_read,jira_search,github_search
SUPPORT_COPILOT_TOOL_RESULT_LIMIT=5
SUPPORT_COPILOT_TOOL_TIMEOUT_SECONDS=8

# Log search scans local files or directories in read-only mode.
SUPPORT_COPILOT_LOG_PATHS=/var/log/support-copilot/auth.log
SUPPORT_COPILOT_LOG_MAX_BYTES=2000000

# Read-only DB queries must be SELECT/WITH and bind tenant_id plus optional request_id/query params.
SUPPORT_COPILOT_READONLY_DATABASE_URL=postgresql://readonly:readonly@localhost:5432/support_metadata
SUPPORT_COPILOT_READONLY_DB_QUERY=SELECT status, reason, updated_at FROM request_metadata WHERE tenant_id = %(tenant_id)s AND request_id = %(request_id)s LIMIT 5

# Jira and GitHub integrations search existing work only; they never create or modify issues.
SUPPORT_COPILOT_JIRA_BASE_URL=https://example.atlassian.net
SUPPORT_COPILOT_JIRA_EMAIL=support@example.com
SUPPORT_COPILOT_JIRA_API_TOKEN=replace-me
SUPPORT_COPILOT_JIRA_PROJECT_KEY=SUP
SUPPORT_COPILOT_GITHUB_REPOS=example-org/example-repo
SUPPORT_COPILOT_GITHUB_TOKEN=replace-me

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Server-side API base used by the Next.js app when browser calls are proxied
# through /support-api in staging/production.
SUPPORT_COPILOT_API_BASE=http://localhost:8000
# Local/demo only. The frontend shows a role picker and sends local identity
# headers for the selected role. Production-like environments ignore local
# identity headers and require trusted gateway/SSO-injected identity context.
NEXT_PUBLIC_SUPPORT_COPILOT_LOCAL_IDENTITY_HEADERS=true
NEXT_PUBLIC_SUPPORT_COPILOT_TENANT_ID=acme
NEXT_PUBLIC_SUPPORT_COPILOT_TENANT_IDS=acme

# Infrastructure
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=support_copilot
POSTGRES_USER=support
POSTGRES_PASSWORD=support
REDIS_URL=redis://localhost:6379/0
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=support-copilot
SUPPORT_COPILOT_READINESS_CHECK_REDIS=false
SUPPORT_COPILOT_READINESS_CHECK_OBJECT_STORAGE=false
SUPPORT_COPILOT_BACKUP_RETENTION_DAYS=30
SUPPORT_COPILOT_AUDIT_RETENTION_DAYS=365
SUPPORT_COPILOT_RUN_TRACE_RETENTION_DAYS=180
