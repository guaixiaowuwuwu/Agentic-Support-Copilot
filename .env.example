# Backend
API_HOST=0.0.0.0
API_PORT=8000
APP_ENV=development

# OpenAI-compatible LLM API for reply draft generation.
# Keep disabled for deterministic local demos; set to true after filling model/API key.
SUPPORT_COPILOT_LLM_ENABLED=false
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=support-copilot-local
LLM_API_KEY=replace-me
LLM_TIMEOUT_SECONDS=20

# Read-only tool whitelist and optional real backends.
# When a backend is not configured, the MVP keeps deterministic demo summaries.
SUPPORT_COPILOT_ALLOWED_TOOLS=log_search,db_read,jira_search,github_search
SUPPORT_COPILOT_TOOL_RESULT_LIMIT=5
SUPPORT_COPILOT_TOOL_TIMEOUT_SECONDS=8

# Log search scans local files or directories in read-only mode.
SUPPORT_COPILOT_LOG_PATHS=/var/log/support-copilot/auth.log
SUPPORT_COPILOT_LOG_MAX_BYTES=2000000

# Read-only DB queries must be SELECT/WITH and bind tenant_id plus optional request_id/query params.
SUPPORT_COPILOT_READONLY_DATABASE_URL=postgresql://readonly:readonly@localhost:5432/support_metadata
SUPPORT_COPILOT_READONLY_DB_QUERY=SELECT status, reason, updated_at FROM request_metadata WHERE tenant_id = %(tenant_id)s AND request_id = %(request_id)s LIMIT 5

# Jira and GitHub integrations search existing work only; they never create or modify issues.
SUPPORT_COPILOT_JIRA_BASE_URL=https://example.atlassian.net
SUPPORT_COPILOT_JIRA_EMAIL=support@example.com
SUPPORT_COPILOT_JIRA_API_TOKEN=replace-me
SUPPORT_COPILOT_JIRA_PROJECT_KEY=SUP
SUPPORT_COPILOT_GITHUB_REPOS=example-org/example-repo
SUPPORT_COPILOT_GITHUB_TOKEN=replace-me

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_SUPPORT_COPILOT_USER_EMAIL=lead@acme.example
NEXT_PUBLIC_SUPPORT_COPILOT_TENANT_ID=acme
NEXT_PUBLIC_SUPPORT_COPILOT_TENANT_IDS=acme
NEXT_PUBLIC_SUPPORT_COPILOT_USER_ROLES=support_agent,approver

# Infrastructure
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=support_copilot
POSTGRES_USER=support
POSTGRES_PASSWORD=support
REDIS_URL=redis://localhost:6379/0
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=support-copilot
